{
  "name": "NekoBT",
  "id": "nekobt",
  "version": "2.0.0",
  "baseUrl": "https://nekobt.to/api/v1/",

  "search": {
    "endpoint": "torrents/search",
    "params": {
      "tmdb_id": "{{tmdbId}}",
      "tvdb_id": "{{tvdbId}}",
      "imdb_id": "{{imdbId}}",
      "fansub_lang": "en,enm",
      "sub_lang": "en,enm",
      "episode": "{{episode}}"
    }
  },

  "response": {
    "results": "results",
    "map": {
      "title": "title",
      "url": "https://nekobt.to/api/v1/torrents/{{id}}/download?public=true",
      "seeders": "seeders",
      "leechers": "leechers",
      "size": "filesize",
      "hash": "infohash"
    }
  },

  "test": "announcements"
}
